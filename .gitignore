# ============================================
# SOA & Microservices Textbook — .gitignore
# ============================================

# ----- Copyrighted reference materials -----
# DO NOT commit — these are personal reference copies
references/*.pdf
references/extracted/

# ----- AI agent config (personal workflows) -----
.agents/
.gemini/

# ----- Build outputs -----
output/
_build/
_output/
*.epub
*.mobi

# ----- Embedded runtimes -----
python-embed.zip
python_env/

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Editor / IDE -----
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*

# ----- Node (if using build tools) -----
node_modules/
package-lock.json

# ----- Python -----
__pycache__/
*.pyc
.venv/
venv/

# ----- Java / Maven / Gradle (code examples) -----
*.class
target/
build/
.gradle/
*.jar
*.war

# ----- Docker -----
docker-compose.override.yml

# ----- Temporary / local -----
*.tmp
*.bak
*.log
*.local.md
tracked_files.txt
