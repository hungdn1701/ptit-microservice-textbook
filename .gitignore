# ============================================
# SOA & Microservices Textbook — .gitignore
# ============================================

# ----- Copyrighted reference materials -----
# DO NOT commit — these are personal reference copies
references/*.pdf
references/extracted/

# ----- AI agent config (personal workflows) -----
.agents/
.gemini/

# ----- Internal authoring docs (private submodule) -----
IDEAS.md
PROGRESS.md
CHANGELOG.md
manuscript/storyline-analysis.md
manuscript/style-guide.md
manuscript/book-outline.md
manuscript/archive/
manuscript/appendices/

# ----- Gen scripts & build tools (private submodule) -----
scripts/gen_svg_*.py
scripts/pdf_to_md.py
scripts/render-diagrams.ps1
scripts/audit-interactive-css.ps1
scripts/build-pdf.ps1
scripts/mmdc-*.json

# ----- Test/temporary figures -----
figures/shared/test*

# ----- Build outputs -----
output/
_build/
_output/
*.epub
*.mobi

# ----- Embedded runtimes -----
python-embed.zip
python_env/

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Editor / IDE -----
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-*
*.code-workspace
# ----- Node (if using build tools) -----
node_modules/
package-lock.json

# ----- Python -----
__pycache__/
*.pyc
.venv/
venv/

# ----- Java / Maven / Gradle (code examples) -----
*.class
target/
build/
.gradle/
*.jar
*.war

# ----- Docker -----
docker-compose.override.yml

# ----- Temporary / local -----
*.tmp
*.bak
*.log
*.local.md
tracked_files.txt

# Typst auto-generated (from Pandoc conversion — source is .typ files after migration)
typst/chapters/_pandoc-raw/

# Test/temp files
_test-*.typ
typst/_test-*.typ
